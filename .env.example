# Orrin configuration — copy to `.env` and fill in what you need:
#
#     cp .env.example .env
#
# Everything here is OPTIONAL. With an empty .env Orrin still runs: it stays
# symbolic-only (no LLM) and web search falls back to searching its own files.
# See the README "Useful environment switches" table for the full (~70) set.

# --- API keys (optional; each unlocks a capability) ---
# OpenAI enables the LLM tool. Without it, Orrin runs symbolic-only.
# OPENAI_API_KEY=sk-...
# Serper.dev (https://serper.dev) enables live web search. Without it,
# "looking outward" falls back to searching Orrin's own files.
# SERPER_API_KEY=...

# Keep the LLM as an explicit tool Orrin calls, not background cognition.
ORRIN_LLM_TOOL_ONLY=1
# Optional daily LLM token cap (cost control). Unset = no cap.
# ORRIN_LLM_DAILY_TOKEN_BUDGET=200000

# --- UI / runtime ---
# Default: Orrin opens a NATIVE desktop window (pywebview) over the built UI — no
# browser tab, no Vite/npm at runtime. Set ORRIN_UI=0 to run headless (no UI).
# ORRIN_UI=1
# Developer path: run the Vite dev server + open a browser tab instead of the
# native window (hot-reload). Keeps the conventional ports (backend 8800, Vite
# 5173) so the Vite proxy works.
# ORRIN_UI_DEV=1
# ORRIN_UI_OPEN=1   (dev path only: 0 starts Vite but doesn't auto-open a tab)
# Override where the built UI is served from (defaults to frontend/dist).
# ORRIN_UI_DIST=/path/to/frontend/dist
# Prometheus metrics exporter is OFF by default (a shipped app opens no port).
# Enable it (OS-assigned port, or pin with ORRIN_METRICS_PORT).
# ORRIN_METRICS=1
# ORRIN_METRICS_PORT=9100
# Seconds between cognitive cycles.
# ORRIN_CYCLE_SLEEP=1

# --- Networking ---
# Where the telemetry backend binds. Use 0.0.0.0 to reach it from another device
# (e.g. Docker, LAN, Tailscale); 127.0.0.1 for localhost-only.
# ORRIN_BACKEND_HOST=127.0.0.1
# Telemetry port. Native window mode uses an OS-assigned free port unless pinned
# here; the dev path defaults to 8800. Pin it for remote viewing.
# ORRIN_BACKEND_PORT=8800
# Remote viewing only: tell the browser which host:port to reach the backend at
# (a LAN/Tailscale IP). Leave unset for plain localhost use.
# VITE_TELEMETRY_HOST=192.168.1.50:8800
# If you serve the UI from a tunnel with a distinct public origin, allowlist it
# so its browser requests are trusted (comma-separated). The local Vite origin
# (:5173) and the backend host are trusted automatically. (UI_AUDIT H1–H3.)
# ORRIN_EXTRA_ORIGINS=https://orrin.my-tunnel.example

# --- Security (only needed when the backend is reachable beyond localhost) ---
# Require a token to READ telemetry (REST + WebSocket) from non-loopback clients.
# The frontend sends VITE_READ_TOKEN (used for the WS ?token= handshake too).
# ORRIN_READ_TOKEN=change-me
# VITE_READ_TOKEN=change-me
# Require a token on POST /ingest so a remote-exposed backend only accepts
# telemetry from the real cognitive loop (the loop reads the same var and sends
# it). Unset = loopback dev is zero-config.
# ORRIN_INGEST_TOKEN=change-me

# --- Misc ---
# Strict fail-closed mode: surface errors instead of degrading silently.
# ORRIN_STRICT=0
# Require this token on /api/control/* (e.g. the UI Stop button); the frontend
# reads VITE_CONTROL_TOKEN. Leave unset for localhost-only dev.
# ORRIN_CONTROL_TOKEN=change-me
