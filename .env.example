# Orrin configuration — copy to `.env` and fill in what you need:
#
#     cp .env.example .env
#
# Everything here is OPTIONAL. With an empty .env Orrin still runs: it stays
# symbolic-only (no LLM) and web search falls back to searching its own files.
# See the README "Useful environment switches" table for the full (~70) set.

# --- API keys (optional; each unlocks a capability) ---
# OpenAI enables the LLM tool. Without it, Orrin runs symbolic-only.
# OPENAI_API_KEY=sk-...
# Serper.dev (https://serper.dev) enables live web search. Without it,
# "looking outward" falls back to searching Orrin's own files.
# SERPER_API_KEY=...

# Keep the LLM as an explicit tool Orrin calls, not background cognition.
ORRIN_LLM_TOOL_ONLY=1
# Optional daily LLM token cap (cost control). Unset = no cap.
# ORRIN_LLM_DAILY_TOKEN_BUDGET=200000

# --- UI / runtime ---
# Set ORRIN_UI=0 to run headless (no web UI). ORRIN_UI_OPEN=0 starts the UI but
# doesn't auto-open a browser tab.
# ORRIN_UI=1
# ORRIN_UI_OPEN=1
# Seconds between cognitive cycles.
# ORRIN_CYCLE_SLEEP=1

# --- Networking ---
# Where the telemetry backend binds. Use 0.0.0.0 to reach it from another device
# (e.g. Docker, LAN, Tailscale); 127.0.0.1 for localhost-only.
# ORRIN_BACKEND_HOST=127.0.0.1
# ORRIN_BACKEND_PORT=8800
# Remote viewing only: tell the browser which host:port to reach the backend at
# (a LAN/Tailscale IP). Leave unset for plain localhost use.
# VITE_TELEMETRY_HOST=192.168.1.50:8800

# --- Misc ---
# Strict fail-closed mode: surface errors instead of degrading silently.
# ORRIN_STRICT=0
# Require this token on /api/control/* (e.g. the UI Stop button); the frontend
# reads VITE_CONTROL_TOKEN. Leave unset for localhost-only dev.
# ORRIN_CONTROL_TOKEN=change-me
