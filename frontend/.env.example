# Copy to .env.local and adjust as needed.

# WebSocket the UI connects to for telemetry. If unset, defaults to
# ws://<VITE_TELEMETRY_HOST or 127.0.0.1:8800>/ws/telemetry
# VITE_TELEMETRY_WS=ws://127.0.0.1:8800/ws/telemetry
# VITE_TELEMETRY_HOST=127.0.0.1:8800

# Force the client-side synthetic demo stream (no backend needed): set to 1.
# VITE_TELEMETRY_DEMO=1

# Fall back to the synthetic demo stream ONLY when the live telemetry connection
# fails to establish (live preferred, demo as a safety net): set to 1.
# VITE_TELEMETRY_DEMO_FALLBACK=1

# HTTP base for the telemetry backend (input pipeline: /api/agent/*).
# Defaults to http://<VITE_TELEMETRY_HOST or 127.0.0.1:8800>.
# VITE_API_URL=http://127.0.0.1:8800

# Optional: a direct synchronous chat endpoint for the Face. If unset, the Face
# uses the input pipeline (POST /api/agent/input + poll for the loop's reply),
# and falls back to local reflection if the backend is unreachable.
# Expected: POST {message} -> {reply}
# VITE_CHAT_URL=http://127.0.0.1:8800/chat

# Shared secret for destructive control actions (e.g. POST /api/control/shutdown),
# sent as the `X-Orrin-Control-Token` header. The BACKEND must require this on
# /api/control/* and reject cross-origin requests. Until then, do not expose this
# UI beyond localhost while the shutdown route is unauthenticated.
# VITE_CONTROL_TOKEN=change-me
